# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local verification artifacts
/tmp

# typescript
*.tsbuildinfo
next-env.d.ts

supabase/.temp/
.claude/scheduled_tasks.lock

# Resumable-bake checkpoint state (ADR-046/047) — transient run artifacts the
# bake scripts write for --resume; never source.
.bake-cards-state.json
.bake-poketrace-state.json

# GSC service-account key — the raw JSON must NEVER be committed (ADR-109 / gsc-api-integration).
# The key is stored base64 in .env.local as GSC_SA_KEY_JSON; this is defensive coverage
# in case the raw file is ever dropped in the repo.
gsc-sa-key.json
*-sa-key.json
*.iam.gserviceaccount.com.json
*n8n-content-project*.json
*service-account*.json

# Creator-content ingestion: raw transcripts are gitignored (synthesized
# digests in docs/transcript-digests/ are committed). Goal C.1 / ADR-050.
docs/transcripts/

# X-bot dry-run drafts (local review artifacts; not source)
docs/social-drafts/

# Obsidian vault UI config (docs/ is opened as a vault; its workspace/layout
# state is per-machine and shouldn't pollute the repo).
docs/.obsidian/

# Cowork goal handoff: NEXT-GOAL.md is written by the Cowork strategy session
# and read by Claude Code as the goal instruction. Transient, never committed.
docs/goals/

# Vending blueprint source PDFs (John's raw operator material — internal sales
# scripts, contract templates, rebuttals). The distilled, host-facing context
# lives in the committed docs/vending/*.md; the raw PDFs stay out of the repo
# (internal-only tactics must not ship; also avoids binary bloat).
docs/vending/source-pdfs/

# QA tour recordings (large, never in git)
design-loop/tour-videos/

# Graphify codebase-graph output (generated, ~7.6MB — regenerate, never commit).
# The .graphifyignore config IS committed so the scan is reproducible.
graphify-out/
