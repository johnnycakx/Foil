{
  "name": "foil",
  "version": "0.1.0",
  "private": true,
  "//browserslist": "Modern target (homepage-perf-and-a11y): drops SWC's ES2022 polyfills/transforms (Array.at/flat/flatMap, Object.fromEntries/hasOwn, String.trimStart/End) — all Baseline since Safari 15.4 (Mar 2022). Trims the legacy-JS chunk; the floor still covers ~all current users.",
  "browserslist": [
    "chrome >= 92",
    "edge >= 92",
    "firefox >= 90",
    "safari >= 15.4",
    "ios_saf >= 15.4",
    "not dead"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "bake:cards": "node --experimental-strip-types --no-warnings scripts/bake-card-metadata.ts",
    "og:cards": "node --experimental-strip-types --no-warnings scripts/generate-og-card-art.ts",
    "bake:poketrace-uuids": "node --experimental-strip-types --no-warnings scripts/bake-poketrace-uuids.ts",
    "expand:top5-per-set": "node --experimental-strip-types --no-warnings scripts/expand-top5-per-set.ts",
    "compliance:check": "node --experimental-strip-types --no-warnings scripts/compliance-check.ts",
    "design:lint": "impeccable detect app/ components/ --json || true",
    "compliance:pdf": "node --experimental-strip-types --no-warnings scripts/generate-compliance-pdf.ts",
    "setup:news-subdomain": "node --experimental-strip-types --no-warnings scripts/setup-news-subdomain.ts",
    "subscriber-sources": "node --experimental-strip-types --no-warnings scripts/subscriber-sources.ts",
    "test": "node --experimental-strip-types --no-warnings --test \"lib/__tests__/*.test.ts\" \"scripts/__tests__/*.test.ts\"",
    "goals:watch": "node --experimental-strip-types --no-warnings scripts/goal-runner.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@beehiiv/sdk": "^0.1.9",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.6",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "@types/mdx": "^2.0.13",
    "@vercel/analytics": "^2.0.1",
    "cheerio": "^1.2.0",
    "google-auth-library": "^10.9.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.15.0",
    "h264-mp4-encoder": "^1.0.12",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-pretty-code": "^0.14.3",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^22.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "impeccable": "^2.1.9",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
